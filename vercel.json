{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "corepack enable && yarn workspace @minneapolisstartribune/design-system build-storybook:web",
  "outputDirectory": "packages/design-system/storybook-static",
  "framework": null,
  "installCommand": "corepack enable && yarn install",
  "github": {
    "enabled": true,
    "silent": false,
    "autoAlias": true
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
