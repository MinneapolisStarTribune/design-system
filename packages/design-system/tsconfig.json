{
  "compilerOptions": {
    // Paths
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "isolatedModules": true,
    "jsx": "react-jsx",
    // Module system
    "module": "ESNext",
    "moduleResolution": "bundler",
    // Build output
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"],
      "@storybook-config/*": ["./.storybook/*"]
    },

    "resolveJsonModule": true,

    "skipLibCheck": true,
    "sourceMap": true,

    // Strictness
    "strict": true,
    "target": "ESNext",
    // Types
    "types": ["vitest/globals", "@testing-library/jest-dom", "node"]
  },
  "exclude": ["node_modules", "dist", ".storybook"],
  "include": ["src"]
  // Note: Stories are included here for IDE type-checking, but excluded from build by Vite
}
