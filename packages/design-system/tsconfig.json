{
  "compilerOptions": {
    // Paths
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "isolatedModules": true,
    "jsx": "react-jsx",
    // Module system
    "module": "ESNext",
    "moduleResolution": "bundler",
    // Build output
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"],
      "@storybook-config/*": ["./.storybook/*"]
    },

    "resolveJsonModule": true,

    "skipLibCheck": true,
    "sourceMap": true,

    // Strictness
    "strict": true,
    "target": "ESNext",
    // Types
    "types": ["vitest/globals", "@testing-library/jest-dom", "node"]
  },
  "exclude": ["node_modules", "dist"],
  "include": [
    "src",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "types/vite-plugins.d.ts",
    "types/storybook-css.d.ts",
    "vite.config.ts",
    "vite.web.config.ts",
    "vite.native.config.ts",
    "vite.icons.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "e2e/**/*.ts"
  ]
  // Note: Stories are included here for IDE type-checking, but excluded from build by Vite
}
