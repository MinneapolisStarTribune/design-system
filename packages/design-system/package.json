{
  "name": "@minneapolisstartribune/design-system",
  "version": "1.0.2",
  "main": "dist/web/design-system.es.js",
  "module": "dist/web/design-system.es.js",
  "types": "dist/web/index.web.d.ts",
  "exports": {
    "./web": {
      "types": "./dist/web/index.web.d.ts",
      "import": "./dist/web/design-system.es.js",
      "default": "./dist/web/design-system.es.js"
    },
    "./web/*": {
      "default": "./dist/web/*"
    },
    "./web/fonts/font-face/*": {
      "default": "./dist/web/fonts/font-face/*"
    },
    "./native": {
      "types": "./dist/mobile/index.native.d.ts",
      "import": "./dist/mobile/design-system.es.js",
      "default": "./dist/mobile/design-system.es.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MinneapolisStarTribune/design-system"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@chromatic-com/storybook": "^4.1.3",
    "@floating-ui/react": "0.27.19",
    "@floating-ui/react-native": "0.10.9",
    "@octokit/rest": "^22.0.1",
    "@react-native/babel-preset": "^0.84.1",
    "@react-native/jest-preset": "0.85.0-nightly-20260219-44901aaf9",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-onboarding": "^10.1.11",
    "@storybook/addon-themes": "^10.1.11",
    "@storybook/addon-vitest": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@svgr/core": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-native": "^13.3.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4",
    "@types/node": "^25.0.10",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/react-test-renderer": "^19",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "axe-core": "^4.11.0",
    "babel-jest": "^30.2.0",
    "chromatic": "^13.3.3",
    "cross-env": "^10.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "eslint-plugin-sort-array-values": "^0.1.0",
    "eslint-plugin-storybook": "^10.1.11",
    "eslint-plugin-unicorn": "^55.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jest": "^30.2.0",
    "jsdom": "^27.2.0",
    "lodash": "^4.17.23",
    "playwright": "^1.54.1",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-sort-json": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "^0.73.0",
    "react-test-renderer": "^19.2.4",
    "sass": "^1.97.2",
    "storybook": "^10.1.11",
    "style-dictionary": "^4.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^3.2.4",
    "vitest-axe": "^0.1.0"
  },
  "peerDependencies": {
    "@floating-ui/react": "0.27.19",
    "@floating-ui/react-native": "0.10.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.73.0"
  },
  "peerDependenciesMeta": {
    "@floating-ui/react": {
      "optional": true
    },
    "@floating-ui/react-native": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "scripts": {
    "build": "yarn clean:dist && yarn tokens && yarn icons && yarn build:web && yarn build:native",
    "build:native": "cross-env NODE_ENV=production vite build --config vite.native.config.ts",
    "build:web": "cross-env NODE_ENV=production vite build --config vite.web.config.ts",
    "build-storybook": "yarn tokens && yarn icons && storybook build",
    "clean:dist": "rm -rf dist",
    "fonts:fetch": "node scripts/fetch-fonts.js",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\" \"tokens/**/*.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\" \"tokens/**/*.json\"",
    "icons": "node scripts/builders/build-icon-mapping.js && prettier --write src/components/Icon/iconOptions.ts",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0 --ignore-path ../../.eslintignore",
    "lint:fix": "eslint . --ext .ts,.tsx --fix --ignore-path ../../.eslintignore",
    "pretest": "yarn tokens",
    "pretest:a11y": "yarn tokens",
    "pretest:native": "yarn tokens",
    "storybook": "node scripts/builders/build-if-needed.js && storybook dev -p 6006",
    "test": "vitest run && jest --config jest.config.js",
    "test:a11y": "vitest run a11y.test && jest --config jest.config.js --testPathPatterns native.a11y.test",
    "test:coverage": "vitest run --coverage",
    "test:native": "jest --config jest.config.js",
    "test:scripts": "vitest run scripts/*.test.js",
    "test:watch": "vitest",
    "test:web": "vitest run",
    "tokens": "node scripts/builders/build-tokens.js",
    "typecheck": "tsc --noEmit"
  }
}
