{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build-storybook": {
      "dependsOn": ["build"],
      "outputs": ["storybook-static/**"]
    },
    "storybook": {
      "persistent": true,
      "cache": false
    },
    "storybook:ios": {
      "persistent": true,
      "cache": false
    },
    "storybook:android": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:web": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:native": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "tokens": {
      "outputs": ["dist/**", "build/**"]
    },
    "icons": {
      "outputs": []
    }
  }
}
