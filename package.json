{
  "name": "@minneapolisstartribune/design-system",
  "version": "1.1.0",
  "main": "dist/web/root-entry-error.cjs.js",
  "module": "dist/web/design-system.es.js",
  "types": "dist/web/index.web.d.ts",
  "exports": {
    ".": {
      "types": "./dist/web/index.web.d.ts",
      "require": "./dist/web/root-entry-error.cjs.js",
      "import": "./dist/web/root-entry-error.cjs.js",
      "default": "./dist/web/root-entry-error.cjs.js"
    },
    "./web": {
      "types": "./dist/web/index.web.d.ts",
      "require": "./dist/web/design-system.cjs.js",
      "import": "./dist/web/design-system.es.js",
      "default": "./dist/web/design-system.es.js"
    },
    "./web/*": {
      "default": "./dist/web/*"
    },
    "./native": {
      "types": "./dist/mobile/index.native.d.ts",
      "import": "./dist/mobile/design-system.es.js",
      "default": "./dist/mobile/design-system.es.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MinneapolisStarTribune/design-system"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@tamagui/popover": "^1.100.0",
    "@tamagui/core": "^1.100.0",
    "@tamagui/config": "^1.100.0",
    "@tamagui/vite-plugin": "^1.100.0",
    "@vitejs/plugin-react": "^4.7.0",
    "axe-core": "^4.11.0",
    "classnames": "^2.5.1",
    "eslint-plugin-react": "^7.37.5",
    "path": "^0.12.7",
    "sass": "^1.97.2",
    "vitest-axe": "^0.1.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-themes": "^10.1.11",
    "@octokit/rest": "^22.0.1",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-onboarding": "^10.1.11",
    "@storybook/addon-vitest": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@svgr/core": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.10",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "chromatic": "^13.3.3",
    "cross-env": "^10.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "eslint-plugin-storybook": "^10.1.11",
    "eslint-plugin-unicorn": "^55.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jsdom": "^27.2.0",
    "lint-staged": "^16.2.6",
    "playwright": "^1.54.1",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-sort-json": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "^0.73.0",
    "storybook": "^10.1.11",
    "style-dictionary": "^4.4.0",
    "typescript": "^5.8.3",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@tamagui/core": "^1.100.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": ">=0.73.0"
  },
  "scripts": {
    "tokens": "node scripts/builders/build-tokens.js",
    "fonts:fetch": "node scripts/fetch-fonts.js",
    "tokens:tamagui": "node scripts/builders/build-tamagui-tokens.js && prettier --write \"src/generated/**/*.ts\"",
    "icons": "node scripts/builders/build-icon-mapping.js && prettier --write src/components/Icon/iconOptions.ts",
    "clean:dist": "rm -rf dist",
    "build": "npm run clean:dist && npm run tokens && npm run tokens:tamagui && npm run icons && npm run build:web && npm run build:native && node scripts/create-root-entry-error.cjs",
    "build:web": "cross-env NODE_ENV=production vite build --config vite.web.config.ts",
    "build:native": "cross-env NODE_ENV=production vite build --config vite.native.config.ts",
    "pretest": "yarn tokens:tamagui",
    "storybook": "node scripts/builders/build-if-needed.js && cross-env TAMAGUI_TARGET=web storybook dev -p 6006",
    "build-storybook": "npm run tokens && npm run tokens:tamagui && npm run icons && storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pretest:a11y": "yarn tokens:tamagui",
    "test:a11y": "vitest run a11y.test",
    "test:scripts": "vitest run scripts/*.test.js",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\" \"tokens/**/*.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\" \"tokens/**/*.json\"",
    "typecheck": "tsc --noEmit",
    "prepare": "npx husky"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
